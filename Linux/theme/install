git clone https://github.com/vinceliuice/WhiteSur-gtk-theme.git && git clone https://github.com/vinceliuice/WhiteSur-icon-theme.git && git clone https://github.com/vinceliuice/WhiteSur-kde.git && git clone https://github.com/vinceliuice/WhiteSur-cursors.git && git clone https://github.com/vinceliuice/grub2-themes.git

mkdir /home/slaweekq/.themes && mkdir /home/slaweekq/.icons

./WhiteSur-gtk-theme/install.sh && ./WhiteSur-icon-theme/install.sh && ./WhiteSur-cursors/install.sh && ./WhiteSur-kde/install.sh

./grub2-themes/install.sh -t whitesur -i whitesur -s 2k -b

